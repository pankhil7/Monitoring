# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to SQLite database file (use :memory: for in-memory, lost on restart)
DATABASE_PATH=monitoring.db

# ── Health Polling (active service health checks) ────────────────────────────
# How often (seconds) the health-check job polls each registered service's URL
HEALTH_CHECK_INTERVAL_SECONDS=60
# HTTP timeout (seconds) for each poll request
HEALTH_CHECK_TIMEOUT_SECONDS=5.0
# Number of consecutive failed checks before a SERVICE_UNREACHABLE alert fires
# (prevents noise from transient single-tick network blips)
HEALTH_CHECK_CONSECUTIVE_FAILURES=3

# ── Aggregation pipeline ──────────────────────────────────────────────────────
# How often (seconds) the processing pipeline runs
AGGREGATION_INTERVAL_SECONDS=60
# Trailing window of events counted per (service, endpoint)
AGGREGATION_WINDOW_MINUTES=5
# How many past windows to keep for trend/spike comparison
HISTORY_WINDOWS=3

# ── Global alert thresholds (overridable per-service/endpoint via Admin API) ──
DEFAULT_HIGH_FREQUENCY_THRESHOLD=10
DEFAULT_SPIKE_RATIO_THRESHOLD=2.0
DEFAULT_SPIKE_MIN_CURRENT_COUNT=5
DEFAULT_REPEATED_IDENTICAL_MIN_COUNT=5
DEFAULT_FAILURE_RATIO_WINDOW=3

# ── Predictive detection thresholds ──────────────────────────────────────────
# Fire "potential_outage" when rate grows by at least this % vs previous window
DEFAULT_PREDICTIVE_RATE_INCREASE_PCT=200.0
# Minimum errors in current window before predictive triggers
DEFAULT_PREDICTIVE_MIN_COUNT=3
# Number of consecutive increasing windows to confirm an upward trend
DEFAULT_PREDICTIVE_TREND_WINDOWS=3

# ── Severity derivation (count → P0/P1/P2, no client input) ──────────────────
# count >= P0_THRESHOLD → P0; >= P1_THRESHOLD → P1; else P2
SEVERITY_P0_COUNT_THRESHOLD=50
SEVERITY_P1_COUNT_THRESHOLD=10

# ── Noise reduction ───────────────────────────────────────────────────────────
# Minimum minutes before the same alert key fires again
DEFAULT_ALERT_COOLDOWN_MINUTES=15
# Re-alert within cooldown if count grows by this factor (worsening)
DEFAULT_WORSEN_RATIO=2.0
# Consecutive clean windows before an incident is marked resolved
DEFAULT_RESOLVED_CLEAN_WINDOWS=2

# ── Notification channels (leave blank to skip that channel) ─────────────────
SLACK_WEBHOOK_URL=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
